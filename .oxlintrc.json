{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    {
      "name": "honk",
      "specifier": "./tooling/scripts/product-design/oxlint-plugin.mjs"
    },
    {
      "name": "react-doctor",
      "specifier": "oxlint-plugin-react-doctor"
    }
  ],
  "plugins": ["typescript", "oxc", "import"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist",
    "dist-electron",
    "node_modules",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts"
  ],
  "rules": {
    "react-doctor/no-set-state-in-render": "error",
    "react-doctor/react-compiler-no-manual-memoization": "warn",
    "typescript/consistent-return": "off",
    "typescript/unbound-method": [
      "error",
      {
        "ignoreStatic": true
      }
    ],
    "import/no-cycle": [
      "error",
      {
        "ignoreExternal": true
      }
    ],
    "import/no-self-import": "error",
    "import/default": "off",
    "import/namespace": "off",
    "import/no-named-as-default": "off",
    "import/no-named-as-default-member": "off"
  },
  "overrides": [
    {
      "files": ["packages/marketing/**"],
      "rules": {
        "react-doctor/react-compiler-no-manual-memoization": "off"
      }
    },
    {
      "files": ["packages/app/**", "packages/desktop/**"],
      "rules": {
        "import/no-cycle": "warn",
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              "@honk/contracts",
              "@honk/contracts/*",
              "@honk/runtime",
              "@honk/runtime/*",
              "@honk/client-runtime",
              "@honk/client-runtime/*"
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/shared/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": ["@honk/contracts", "@honk/contracts/*"]
          }
        ]
      }
    },
    {
      "files": ["packages/ui/src/**/*.{ts,tsx}", "packages/ui/dev/**/*.{ts,tsx}"],
      "rules": {
        "honk/design-no-banned-imports": "error",
        "honk/design-no-border-shorthand": "error",
        "honk/design-no-container-queries": "error",
        "honk/design-no-cross-element": "error",
        "honk/design-no-duplicate-define-vars": "error",
        "honk/design-no-null-stylex-overrides": "error",
        "honk/design-no-raw-values": "error",
        "honk/design-no-use-effect": "error"
      }
    },
    {
      "files": ["packages/app/src/**/*.{ts,tsx}"],
      "rules": {
        "honk/design-no-border-shorthand": "error",
        "honk/design-no-canonical-control-overrides": "error",
        "honk/design-no-container-queries": "error",
        "honk/design-no-cross-element": "error",
        "honk/design-no-null-stylex-overrides": "error",
        "honk/design-no-raw-button": "error",
        "honk/design-no-raw-values": "error"
      }
    },
    {
      "files": ["packages/mobile/**/*.{ts,tsx}"],
      "rules": {
        "honk/design-no-canonical-control-overrides": "error"
      }
    },
    {
      "files": ["packages/ui/src/**/*.{ts,tsx}"],
      "rules": {
        "honk/design-no-host-styling": "error"
      }
    },
    {
      "files": [
        "packages/cli/src/**/*.{ts,tsx}",
        "packages/desktop/src/**/*.{ts,tsx}",
        "packages/shared/src/**/*.{ts,tsx}"
      ],
      "rules": {
        "honk/effect-v4-syntax": "error"
      }
    }
  ],
  "env": {
    "builtin": true
  }
}
