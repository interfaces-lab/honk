{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "jsPlugins": [
    {
      "name": "react-doctor",
      "specifier": "oxlint-plugin-react-doctor"
    }
  ],
  "plugins": ["typescript", "oxc"],
  "options": {
    "typeAware": true
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "dist",
    "dist-electron",
    "node_modules",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts"
  ],
  "rules": {
    "react-doctor/no-set-state-in-render": "error",
    "react-doctor/react-compiler-no-manual-memoization": "warn",
    "typescript/consistent-return": "off"
  },
  "overrides": [
    {
      "files": ["packages/marketing/**"],
      "rules": {
        "react-doctor/react-compiler-no-manual-memoization": "off"
      }
    }
  ],
  "env": {
    "builtin": true
  }
}
