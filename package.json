{
  "name": "@honk/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts"
    ]
  },
  "type": "module",
  "scripts": {
    "prepare": "node scripts/prepare-effect-language-service.mjs",
    "dev": "turbo run dev --filter=@honk/desktop",
    "dev:app": "turbo run dev --filter=@honk/app",
    "dev:desktop": "turbo run dev --filter=@honk/desktop",
    "start:desktop": "turbo run start --filter=@honk/desktop",
    "start:mock-update-server": "bun scripts/mock-update-server.ts",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@honk/desktop",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives && pnpm run konsistent && pnpm run lint:css",
    "lint:css": "stylelint \"packages/**/*.css\" --allow-empty-input",
    "konsistent": "konsistent check",
    "konsistent:ci": "konsistent check --format=github",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@honk/desktop",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "knip": "knip --include-entry-exports --no-progress --no-config-hints",
    "knip:production": "knip --production --include-entry-exports --no-progress --no-config-hints",
    "dist:desktop:artifact": "turbo run package --filter=@honk/desktop",
    "dist:desktop:dmg": "turbo run package:mac --filter=@honk/desktop",
    "dist:desktop:dmg:arm64": "turbo run package:mac --filter=@honk/desktop -- --arm64",
    "dist:desktop:dmg:x64": "turbo run package:mac --filter=@honk/desktop -- --x64",
    "dist:desktop:linux": "turbo run package:linux --filter=@honk/desktop -- --x64",
    "release:bump": "bumpp --no-commit --no-tag --no-push packages/desktop/package.json packages/app/package.json",
    "release:smoke": "pnpm --filter=@honk/release-scripts run test",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/dist-electron packages/*/out .turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs",
    "doctor": "npx react-doctor@latest"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "catalog:",
    "@types/node": "catalog:",
    "bumpp": "11.1.0",
    "bun": "catalog:",
    "knip": "^6.17.1",
    "konsistent": "1.0.0-beta.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-plugin-react-doctor": "0.2.16",
    "oxlint-tsgolint": "^0.23.0",
    "react-doctor": "0.2.16",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "2.10.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "msw": {
    "workerDirectory": [
      "packages/app/public"
    ]
  }
}
