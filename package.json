{
  "name": "@multi/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts"
    ]
  },
  "type": "module",
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:app": "node scripts/dev-runner.ts dev:app",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "start": "turbo run start --filter=usemulti",
    "start:desktop": "turbo run start --filter=@multi/desktop",
    "start:mock-update-server": "bun scripts/mock-update-server.ts",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@multi/desktop --filter=usemulti",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives --deny-warnings && pnpm run lint:css",
    "lint:css": "stylelint \"packages/**/*.css\" --allow-empty-input",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@multi/desktop",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@multi/contracts",
    "knip": "knip --include-entry-exports --no-progress --no-config-hints",
    "knip:production": "knip --production --include-entry-exports --no-progress --no-config-hints",
    "dist:desktop:artifact": "node scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "node scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "node scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "node scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "release:smoke": "node scripts/release-smoke.ts",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/dist-electron .turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@types/node": "catalog:",
    "bun": "catalog:",
    "knip": "^6.14.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vite": "^8.0.14"
  },
  "engines": {
    "node": "25.8.1"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "msw": {
    "workerDirectory": [
      "packages/app/public"
    ]
  }
}
