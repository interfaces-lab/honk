{
  "name": "@multi/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "scripts"
    ]
  },
  "type": "module",
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "turbo run dev --filter=@multi/desktop",
    "dev:server": "turbo run dev --filter=usemulti",
    "dev:app": "turbo run dev --filter=@multi/app",
    "dev:desktop": "turbo run dev --filter=@multi/desktop",
    "start": "turbo run start --filter=usemulti",
    "start:desktop": "turbo run start --filter=@multi/desktop",
    "start:mock-update-server": "bun scripts/mock-update-server.ts",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@multi/desktop",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives --deny-warnings && pnpm run lint:css",
    "lint:css": "stylelint \"packages/**/*.css\" --allow-empty-input",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@multi/desktop",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@multi/contracts",
    "knip": "knip --include-entry-exports --no-progress --no-config-hints",
    "knip:production": "knip --production --include-entry-exports --no-progress --no-config-hints",
    "dist:desktop:artifact": "turbo run package --filter=@multi/desktop",
    "dist:desktop:dmg": "turbo run package:mac --filter=@multi/desktop",
    "dist:desktop:dmg:arm64": "turbo run package:mac --filter=@multi/desktop -- --arm64",
    "dist:desktop:dmg:x64": "turbo run package:mac --filter=@multi/desktop -- --x64",
    "dist:desktop:linux": "turbo run package:linux --filter=@multi/desktop -- --x64",
    "release:smoke": "pnpm --filter=@multi/release-scripts run test",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist packages/*/dist-electron packages/*/out .turbo packages/*/.turbo",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260601.1",
    "bun": "catalog:",
    "knip": "^6.15.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-plugin-react-doctor": "0.2.16",
    "oxlint-tsgolint": "^0.23.0",
    "react-doctor": "0.2.16",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": "25.8.1"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "msw": {
    "workerDirectory": [
      "packages/app/public"
    ]
  }
}
