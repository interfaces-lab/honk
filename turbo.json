{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HOST",
    "PORT",
    "VITE_WS_URL",
    "MULTI_LOG_WS_EVENTS",
    "MULTI_MODE",
    "MULTI_PORT",
    "MULTI_NO_BROWSER",
    "MULTI_HOME",
    "MULTI_AUTH_TOKEN",
    "MULTI_DESKTOP_WS_URL",
    "MULTI_TRACE_MIN_LEVEL",
    "MULTI_TRACE_TIMING_ENABLED",
    "MULTI_TRACE_FILE",
    "MULTI_TRACE_MAX_BYTES",
    "MULTI_TRACE_MAX_FILES",
    "MULTI_TRACE_BATCH_WINDOW_MS",
    "MULTI_OTLP_TRACES_URL",
    "MULTI_OTLP_METRICS_URL",
    "MULTI_OTLP_EXPORT_INTERVAL_MS",
    "MULTI_OTLP_SERVICE_NAME"
  ],
  "globalPassThroughEnv": ["PATHEXT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@multi/contracts#build"],
      "env": ["VITE_DEV_SERVER_URL"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
