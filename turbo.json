{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HONK_TRACE_MIN_LEVEL",
    "HONK_TRACE_TIMING_ENABLED",
    "HONK_TRACE_FILE",
    "HONK_TRACE_MAX_BYTES",
    "HONK_TRACE_MAX_FILES",
    "HONK_TRACE_BATCH_WINDOW_MS",
    "HONK_OTLP_TRACES_URL",
    "HONK_OTLP_METRICS_URL",
    "HONK_OTLP_EXPORT_INTERVAL_MS",
    "HONK_OTLP_SERVICE_NAME"
  ],
  "cacheMaxAge": "1d",
  "globalPassThroughEnv": ["PATHEXT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**", "out/**"]
    },
    "dev": {
      "dependsOn": ["@honk/contracts#build"],
      "env": [
        "HOST",
        "PORT",
        "VITE_DEV_SERVER_URL",
        "VITE_HTTP_URL",
        "VITE_WS_URL",
        "HONK_AUTO_BOOTSTRAP_PROJECT_FROM_CWD",
        "HONK_LOG_WS_EVENTS",
        "HONK_MODE",
        "HONK_PORT",
        "HONK_NO_BROWSER",
        "HONK_HOME",
        "HONK_AUTH_TOKEN",
        "HONK_DESKTOP_WS_URL"
      ],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
