{
  "expo": {
    "name": "Honk",
    "slug": "honk-mobile",
    "scheme": "honk",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.interfacesco.honk.mobile"
    },
    "android": {
      "package": "com.interfacesco.honk.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Honk to attach images to your task messages."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
