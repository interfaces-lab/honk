{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "customConditions": ["react-native"],
    "moduleSuffixes": [".ios", ".android", ".native", ""]
  },
  "include": ["app", "src", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
