{
  "name": "@honk/desktop",
  "version": "0.5.3",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.ts",
    "prebuild": "pnpm --filter usehonk run build",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --config electron-builder.config.ts",
    "package:mac": "electron-builder --mac --config electron-builder.config.ts",
    "package:linux": "electron-builder --linux --config electron-builder.config.ts",
    "package:win": "electron-builder --win --config electron-builder.config.ts",
    "start": "node scripts/start-electron.mjs",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.79.4",
    "@earendil-works/pi-ai": "^0.79.4",
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@honk/runtime": "workspace:*",
    "@lydell/node-pty": "1.2.0-beta.12",
    "@pierre/diffs": "^1.2.11",
    "effect": "catalog:",
    "electron-updater": "^6.8.9",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sqlite3": "5.1.7",
    "typebox": "^1.2.12"
  },
  "devDependencies": {
    "@honk/app": "workspace:*",
    "@honk/contracts": "workspace:*",
    "@honk/shared": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^19.0.0-beta-ebf51a3-20250411",
    "electron": "40.6.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "6.0.0-beta.1",
    "tailwindcss": "^4.3.1",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "vitest": "catalog:"
  },
  "productName": "Honk"
}
