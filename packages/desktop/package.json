    "@tanstack/router-plugin": "^1.168.14",
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "19.0.0-beta-ebf51a3-20250411",
    "electron": "40.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "6.0.0-beta.1",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:",
    "vite": "^8.0.16",
    "vitest": "catalog:"
