{
  "name": "@multi/desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.ts",
    "prebuild": "pnpm --filter usemulti run build",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --config electron-builder.config.ts",
    "package:mac": "electron-builder --mac --config electron-builder.config.ts",
    "package:linux": "electron-builder --linux --config electron-builder.config.ts",
    "start": "node scripts/start-electron.mjs",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke-test": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.163",
    "@earendil-works/pi-agent-core": "^0.78.1",
