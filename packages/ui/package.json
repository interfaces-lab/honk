{
  "name": "@honk/ui",
  "version": "0.0.0",
  "private": true,
  "description": "The client family's design-system layer (ADR 0023). Raw TS source; StyleX primitives plus a Tailwind v4 token bridge (src/tailwind.css) for layout utilities. Consumers must run @stylexjs/unplugin and add optimizeDeps.exclude: ['@honk/ui'].",
  "type": "module",
  "exports": {
    ".": {
      "react-native": "./src/index.native.ts",
      "default": "./src/index.ts"
    },
    "./assistant-message": "./src/assistant-message.tsx",
    "./compaction-divider": "./src/compaction-divider.tsx",
    "./icons": "./src/icons.ts",
    "./notice-row": "./src/notice-row.tsx",
    "./platform-tokens.css": "./src/platform-tokens.css",
    "./platform-tokens.stylex": "./src/platform-tokens.stylex.ts",
    "./plan-card": "./src/plan-card.tsx",
    "./picker": {
      "react-native": "./src/picker.native.tsx",
      "default": "./src/picker.tsx"
    },
    "./prose-code-block": "./src/prose-code-block.ts",
    "./reasoning-block": "./src/reasoning-block.tsx",
    "./timeline-navigator": "./src/timeline-navigator.tsx",
    "./text-field": {
      "react-native": "./src/text-field/index.native.tsx",
      "default": "./src/text-field/index.web.tsx"
    },
    "./theme": "./src/theme.ts",
    "./tokens.stylex": "./src/tokens.stylex.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "sync:tokens": "node scripts/sync-platform-tokens.mjs",
    "check:tokens": "node scripts/sync-platform-tokens.mjs --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@stylexjs/stylex": "0.19.0",
    "central-icons": "npm:@central-icons-react/round-outlined-radius-2-stroke-1.5@^1.1.294",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@stylexjs/unplugin": "0.19.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-router": "^1.170.18",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dialkit": "^1.3.0",
    "motion": "^12.42.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:",
    "vite": "^8.1.4"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": ">=0.83.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-worklets": ">=0.7.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-worklets": {
      "optional": true
    }
  }
}
